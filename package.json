{
  "name": "@jasperdenouden92/annotations",
  "version": "2.7.5",
  "description": "Client-facing annotation engine voor alle projecten",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.js"
    }
  },
  "bin": {
    "annotate-scan": "./bin/annotate-scan.js",
    "annotate-init": "./bin/annotate-init.js"
  },
  "files": [
    "dist",
    "bin",
    "CLAUDE.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^18",
    "tsup": "^8",
    "typescript": "~5.6"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jasperdenouden92/annotations.git"
  }
}
